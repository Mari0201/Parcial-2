package com.parcial.modelo;

/**
 * Clase Arma: representa un arma que las criaturas pueden usar (composición).
 * Se usa composición en lugar de herencia para agregar funcionalidad de ataque.
 */
public class Arma {
    private String nombre;
    private int dañoAdicional;

    public Arma(String nombre, int dañoAdicional) {
        this.nombre = nombre;
        this.dañoAdicional = dañoAdicional;
    }

    /**
     * Realiza un ataque con el arma e imprime el resultado.
     */
    public void atacarConArma(Criatura objetivo) {
        System.out.println("  ⚔️ Ataca con " + nombre + " causando " + dañoAdicional + " de daño adicional a " + objetivo.getNombre());
    }

    /**
     * Devuelve el daño adicional del arma.
     */
    public int getDañoAdicional() {
        return dañoAdicional;
    }

    public String getNombre() {
        return nombre;
    }
}
